# Copia este archivo y renómbralo a .env.local
# Luego rellena con tus datos de tu proyecto en https://supabase.com

VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_CLAVE_ANONIMA_AQUI

# --- Notificaciones de cumpleaños por Telegram (Vercel Cron) ---
# Token del bot creado con @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-TU_TOKEN_AQUI
# ID del chat/grupo donde llegarán las notificaciones
TELEGRAM_CHAT_ID=123456789
# (Opcional) Secreto para proteger el endpoint del cron. Vercel lo envía automáticamente.
CRON_SECRET=una_cadena_larga_y_secreta
